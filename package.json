{
  "name": "fitness-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "pnpm db:migrate:runtime && pnpm dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "check": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:component",
    "lint": "eslint",
    "test:component": "vitest run --project component",
    "test:component:watch": "vitest --project component",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --project=chromium",
    "test:unit": "vitest run --project unit",
    "test:unit:watch": "vitest --project unit",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:runtime": "node scripts/run-migrations.mjs",
    "db:backup": "node scripts/backup-db.mjs",
    "db:restore": "node scripts/restore-db.mjs",
    "users:seed": "node --env-file-if-exists=.env --import tsx scripts/seed-user.ts",
    "statistics:seed:demo": "node --env-file-if-exists=.env --import tsx scripts/seed-statistics-demo.ts"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "@mui/material-nextjs": "^7.3.2",
    "@mui/x-charts": "^9.1.0",
    "@node-rs/argon2": "^2.0.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
